# AI Pilot Auth API

# JWT secret (сгенерировать: openssl rand -hex 32)
JWT_SECRET=change-me-to-random-string

# База данных (путь к SQLite файлу)
DATABASE_PATH=./data/aipilot.db

# SMTP для подтверждения email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-password

# URL нашего сервиса
APP_URL=https://pilotsite.ru

# Gateway token (для создания временных токенов)
GATEWAY_TOKEN=f8186e8d77460feeb735a8dbc48e659c9b05c7f10b114fd554d6fd7a8f8e76e3
GATEWAY_WS=ws://localhost:18789
